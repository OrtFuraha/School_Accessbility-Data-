// ── API: accessibility results ────────────────────────────────────────
app.get('/api/gis/accessibility', async (req, res) => {
  try {
    const rows = await dbAll('SELECT * FROM accessibility_results ORDER BY accessibility_score ASC');
    res.json({
      type: 'FeatureCollection',
      metadata: {
        total:       rows.length,
        highly:      rows.filter(r => r.accessibility_class === 'Highly Accessible').length,
        moderate:    rows.filter(r => r.accessibility_class === 'Moderately Accessible').length,
        underserved: rows.filter(r => r.accessibility_class === 'Underserved').length,
      },
      features: rows.map(r => ({
        type: 'Feature',
        properties: r,
        geometry: r.geojson ? JSON.parse(r.geojson) : null,
      })),
    });
  } catch (e) { res.status(500).json({ error: e.message }); }
});

// ── API: underserved areas ────────────────────────────────────────────
app.get('/api/gis/underserved', async (req, res) => {
  try {
    const rows = await dbAll(
      `SELECT * FROM accessibility_results
       WHERE accessibility_class IN ('Underserved','Moderately Accessible')
       ORDER BY accessibility_score ASC`);
    res.json({
      type: 'FeatureCollection',
      features: rows.map(r => ({
        type: 'Feature',
        properties: r,
        geometry: r.geojson ? JSON.parse(r.geojson) : null,
      })),
    });
  } catch (e) { res.status(500).json({ error: e.message }); }
});

// ── API: run analysis ─────────────────────────────────────────────────
app.post('/api/gis/analyze', async (req, res) => {
  try {
    const results = await runAnalysis();
    res.json({ success: true, count: results.length, results });
  } catch (e) { res.status(500).json({ error: e.message }); }
});

// ── API: nearest school ───────────────────────────────────────────────
app.get('/api/gis/nearest-school', async (req, res) => {
  const { lon, lat } = req.query;
  if (!lon || !lat) return res.status(400).json({ error: 'lon and lat required' });
  try {
    const schools = await dbAll('SELECT * FROM schools WHERE lon IS NOT NULL');
    let nearest = null, minDist = Infinity;
    for (const s of schools) {
      const d = haversine(+lon, +lat, s.lon, s.lat);
      if (d < minDist) { minDist = d; nearest = s; }
    }
    res.json({ ...nearest, distance_km: +minDist.toFixed(3) });
  } catch (e) { res.status(500).json({ error: e.message }); }
});

// ── API: health ───────────────────────────────────────────────────────
app.get('/api/health', async (req, res) => {
  try {
    const counts = {};
    for (const t of ['schools','roads','sectors','districts']) {
      const r = await dbGet(`SELECT COUNT(*) AS c FROM ${t}`);
      counts[t] = r?.c || 0;
    }
    res.json({ status: 'ok', counts });
  } catch (e) { res.status(500).json({ status: 'error', error: e.message }); }
});

// ── Serve frontend ────────────────────────────────────────────────────
app.get('/', (req, res) => {
  const idx = path.join(__dirname, 'public', 'index.html');
  if (fs.existsSync(idx)) return res.sendFile(idx);
  res.send(`<h2>Rwanda School Accessibility API</h2>
    <ul>
      <li><a href="/api/gis/stats">/api/gis/stats</a></li>
      <li><a href="/api/gis/schools">/api/gis/schools</a></li>
      <li><a href="/api/gis/roads">/api/gis/roads</a></li>
      <li><a href="/api/gis/sectors">/api/gis/sectors</a></li>
      <li><a href="/api/gis/accessibility">/api/gis/accessibility</a></li>
      <li><a href="/api/gis/underserved">/api/gis/underserved</a></li>
    </ul>`);
});

// ── Start ─────────────────────────────────────────────────────────────
async function start() {
  console.log('╔════════════════════════════════════════════════════════════╗');
  console.log('║     Rwanda School Accessibility — GIS Platform             ║');
  console.log('╚════════════════════════════════════════════════════════════╝');

  getDB();

  const counts = {};
  for (const t of ['schools','roads','sectors','districts']) {
    const r = await dbGet(`SELECT COUNT(*) AS c FROM ${t}`).catch(() => ({c:0}));
    counts[t] = r?.c || 0;
  }

  console.log('\n📊 Database:');
  for (const [t, c] of Object.entries(counts))
    console.log(`   ${t.padEnd(12)}: ${c}`);

  if (counts.schools === 0 || counts.roads === 0) {
    console.log('\n⚠️  Database empty! Run: node build_database.js');
  } else {
    console.log('\n🔍 Running accessibility analysis...');
    try {
      const results = await runAnalysis();
      const highly      = results.filter(r => r.accessibility_class === 'Highly Accessible').length;
      const moderate    = results.filter(r => r.accessibility_class === 'Moderately Accessible').length;
      const underserved = results.filter(r => r.accessibility_class === 'Underserved').length;
      console.log(`\n📊 Analysis Results:`);
      console.log(`   ✅ Total Sectors:         ${results.length}`);
      console.log(`   🟢 Highly Accessible:     ${highly}`);
      console.log(`   🟡 Moderately Accessible: ${moderate}`);
      console.log(`   🔴 Underserved:           ${underserved}`);
    } catch (e) {
      console.warn('   ⚠️  Analysis error:', e.message);
    }
  }

  app.listen(PORT, () => {
    console.log(`\n╔════════════════════════════════════════════════════════════╗`);
    console.log(`║  🗺️  http://localhost:${PORT}                                ║`);
    console.log(`║  GET /api/gis/stats         — Summary counts               ║`);
    console.log(`║  GET /api/gis/schools        — 39 school locations          ║`);
    console.log(`║  GET /api/gis/roads          — 205 road segments            ║`);
    console.log(`║  GET /api/gis/accessibility  — Sector accessibility         ║`);
    console.log(`║  GET /api/gis/underserved    — Underserved areas            ║`);
    console.log(`╚════════════════════════════════════════════════════════════╝`);
  });
}

start().catch(e => { console.error('❌', e.message); process.exit(1); });
