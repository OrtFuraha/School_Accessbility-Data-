const db = new sqlite3.Database(DB_PATH);

// Create tables
db.serialize(() => {
    db.run(`DROP TABLE IF EXISTS schools`);
    db.run(`DROP TABLE IF EXISTS sectors`);
    db.run(`DROP TABLE IF EXISTS roads`);
    
    db.run(`CREATE TABLE schools (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        name TEXT,
        lat REAL,
        lon REAL,
        type TEXT,
        source_file TEXT
    )`);
    
    db.run(`CREATE TABLE sectors (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        name TEXT,
        lat REAL,
        lon REAL,
        population INTEGER,
        source_file TEXT
    )`);
    
    db.run(`CREATE TABLE roads (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        name TEXT,
        type TEXT,
        coordinates TEXT,
        source_file TEXT
    )`);
    
    console.log('✅ Database ready');
});

function calculateDistance(x1, y1, x2, y2) {
    const dx = x2 - x1;
    const dy = y2 - y1;
    return Math.sqrt(dx * dx + dy * dy) / 1000;
}

// Parse shapefile and extract all data
async function parseAndLoadShapefile(shpPath, sourceName) {
    return new Promise(async (resolve) => {
        try {
            const source = await shapefile.open(shpPath);
            const features = [];
            let result;
            
            while (true) {
                result = await source.read();
                if (result.done) break;
                if (result.value) {
                    features.push(result.value);
                }
            }
            
            console.log(`   📍 Found ${features.length} features in ${sourceName}`);
            
            let pointsCount = 0;
            let linesCount = 0;
            let polygonsCount = 0;
            
            for (const feature of features) {
                const geom = feature.geometry;
                const props = feature.properties;
                
                if (geom.type === 'Point') {
                    const lon = geom.coordinates[0];
                    const lat = geom.coordinates[1];
                    const name = props.NAME || props.name || props.School || props.school || `Feature_${pointsCount}`;
                    
                    db.run(`INSERT INTO schools (name, lat, lon, type, source_file) VALUES (?, ?, ?, ?, ?)`,
                        [name, lat, lon, 'point', sourceName]);
                    pointsCount++;
                }
                else if (geom.type === 'LineString') {
                    const coords = geom.coordinates;
                    const name = props.NAME || props.name || props.Road || props.road || `Road_${linesCount}`;
                    const roadType = props.TYPE || props.type || props.Class || 'unknown';
                    
                    db.run(`INSERT INTO roads (name, type, coordinates, source_file) VALUES (?, ?, ?, ?)`,
                        [name, roadType, JSON.stringify(coords), sourceName]);
                    linesCount++;
                }
                else if (geom.type === 'Polygon') {
                    const centroid = geom.coordinates[0].reduce((sum, coord) => [sum[0] + coord[0], sum[1] + coord[1]], [0, 0]);
                    const lon = centroid[0] / geom.coordinates[0].length;
                    const lat = centroid[1] / geom.coordinates[0].length;
                    const name = props.NAME || props.name || props.District || props.district || `Area_${polygonsCount}`;
                    const population = parseInt(props.POPULATION) || parseInt(props.population) || 5000;
                    
                    db.run(`INSERT INTO sectors (name, lat, lon, population, source_file) VALUES (?, ?, ?, ?, ?)`,
                        [name, lat, lon, population, sourceName]);
                    polygonsCount++;
                }
            }
            
            console.log(`      ✅ Points: ${pointsCount}, Lines: ${linesCount}, Polygons: ${polygonsCount}`);
            resolve({ points: pointsCount, lines: linesCount, polygons: polygonsCount });
        } catch (err) {
            console.log(`   ❌ Error parsing ${sourceName}: ${err.message}`);
            resolve({ points: 0, lines: 0, polygons: 0 });
        }
    });
}

// Load all shapefiles
async function loadAllShapefiles() {
    console.log('\n📂 Loading shapefiles from Desktop/DATA folder...');
    
    const files = fs.readdirSync(DATA_PATH);
    const shpFiles = files.filter(f => f.toLowerCase().endsWith('.shp'));
    
    console.log(`\n📄 Found ${shpFiles.length} shapefile(s):`);
    
    let totalPoints = 0;
    let totalLines = 0;
    let totalPolygons = 0;
    
    for (const shpFile of shpFiles) {
        const shpPath = path.join(DATA_PATH, shpFile);
        const name = path.basename(shpFile, '.shp');
        console.log(`\n📄 Processing: ${shpFile}`);
        
        const result = await parseAndLoadShapefile(shpPath, name);
        totalPoints += result.points;
        totalLines += result.lines;
        totalPolygons += result.polygons;
    }
    
    console.log(`\n📊 TOTAL DATA EXTRACTED:`);
    console.log(`   🏫 Points (Schools/Sites): ${totalPoints}`);
    console.log(`   🛣️ Lines (Roads): ${totalLines}`);
    console.log(`   🏘️ Polygons (Sectors/Areas): ${totalPolygons}`);
    
    // If no data extracted, load sample data
    if (totalPoints === 0 && totalLines === 0 && totalPolygons === 0) {
        console.log(`\n⚠️ No data extracted from shapefiles. Loading sample data...`);
        await loadSampleData();
    }
    
    return { points: totalPoints, lines: totalLines, polygons: totalPolygons };
}

