// Generate GeoJSON from database
function generateGeoJSON(type) {
    return new Promise((resolve) => {
        if (type === 'schools') {
            db.all('SELECT * FROM schools', (err, rows) => {
                const features = rows.map(s => ({
                    type: "Feature",
                    geometry: { type: "Point", coordinates: [s.lon, s.lat] },
                    properties: { name: s.name, type: s.type, source: s.source_file }
                }));
                resolve({ type: "FeatureCollection", features: features });
            });
        } else if (type === 'sectors') {
            db.all('SELECT * FROM sectors', (err, rows) => {
                const features = rows.map(s => ({
                    type: "Feature",
                    geometry: { type: "Point", coordinates: [s.lon, s.lat] },
                    properties: { name: s.name, population: s.population, source: s.source_file }
                }));
                resolve({ type: "FeatureCollection", features: features });
            });
        } else if (type === 'roads') {
            db.all('SELECT * FROM roads', (err, rows) => {
                const features = rows.map(r => {
                    let coords = [];
                    try {
                        coords = JSON.parse(r.coordinates);
                    } catch(e) {
                        coords = [];
                    }
                    return {
                        type: "Feature",
                        geometry: { type: "LineString", coordinates: coords },
                        properties: { name: r.name, type: r.type, source: r.source_file }
                    };
                });
                resolve({ type: "FeatureCollection", features: features });
            });
        } else {
            resolve({ type: "FeatureCollection", features: [] });
        }
    });
}

// Save GeoJSON
async function saveGeoJSON() {
    const schools = await generateGeoJSON('schools');
    const sectors = await generateGeoJSON('sectors');
    const roads = await generateGeoJSON('roads');
    
    fs.writeFileSync(path.join(OUTPUTS_PATH, 'schools.geojson'), JSON.stringify(schools, null, 2));
    fs.writeFileSync(path.join(OUTPUTS_PATH, 'sectors.geojson'), JSON.stringify(sectors, null, 2));
    fs.writeFileSync(path.join(OUTPUTS_PATH, 'roads.geojson'), JSON.stringify(roads, null, 2));
    
    console.log(`\n✅ GeoJSON files saved to ${OUTPUTS_PATH}`);
}

// Run accessibility analysis
async function runAnalysis() {
    const sectors = await new Promise(r => db.all('SELECT * FROM sectors', (e, rows) => r(rows || [])));
    const schools = await new Promise(r => db.all('SELECT * FROM schools', (e, rows) => r(rows || [])));
    
    if (sectors.length === 0 || schools.length === 0) {
        return { stats: { total_sectors: 0, highly_accessible: 0, moderately_accessible: 0, underserved_count: 0 } };
    }
    
    const results = sectors.map(sector => {
        let nearest = null;
        let minDist = Infinity;
        schools.forEach(school => {
            const dist = calculateDistance(sector.lat, sector.lon, school.lat, school.lon);
            if (dist < minDist) {
                minDist = dist;
                nearest = school;
            }
        });
        
        let category;
        if (minDist <= 2) category = "Highly Accessible";
        else if (minDist <= 5) category = "Moderately Accessible";
        else category = "Poorly Accessible";
        
        return {
            sector_name: sector.name,
            nearest_school: nearest?.name || 'N/A',
            distance_km: minDist.toFixed(2),
            travel_time_min: (minDist / 30 * 60).toFixed(0),
            category: category,
            population: sector.population
        };
    });
    
    const stats = {
        total_sectors: results.length,
        underserved_count: results.filter(r => r.category === 'Poorly Accessible').length,
        highly_accessible: results.filter(r => r.category === 'Highly Accessible').length,
        moderately_accessible: results.filter(r => r.category === 'Moderately Accessible').length,
        avg_distance_km: (results.reduce((s, r) => s + parseFloat(r.distance_km), 0) / results.length || 0).toFixed(2),
        avg_travel_time_min: (results.reduce((s, r) => s + parseFloat(r.travel_time_min), 0) / results.length || 0).toFixed(0)
    };
    
    console.log(`\n📊 ANALYSIS RESULTS:`);
    console.log(`   ✅ Total Sectors: ${stats.total_sectors}`);
    console.log(`   🟢 Highly Accessible: ${stats.highly_accessible}`);
    console.log(`   🟡 Moderately Accessible: ${stats.moderately_accessible}`);
    console.log(`   🔴 Underserved: ${stats.underserved_count}`);
    
    return { stats };
}

