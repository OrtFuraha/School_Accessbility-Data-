    res.json({ success: true, count: results.length });
});

app.get('/api/results', async (req, res) => {
    const results = await pool.query('SELECT * FROM accessibility_results ORDER BY priority_score DESC');
    const stats = {
        total_sectors: results.rows.length,
        underserved_count: results.rows.filter(r => r.category === 'Poorly Accessible' || r.category === 'Severely Underserved').length,
        highly_accessible: results.rows.filter(r => r.category === 'Highly Accessible').length,
        moderately_accessible: results.rows.filter(r => r.category === 'Moderately Accessible').length,
        avg_distance_km: (results.rows.reduce((s, r) => s + parseFloat(r.distance_km), 0) / results.rows.length || 0).toFixed(2),
        avg_travel_time_min: (results.rows.reduce((s, r) => s + parseFloat(r.travel_time_min), 0) / results.rows.length || 0).toFixed(0)
    };
    res.json({ accessibility: results.rows, statistics: stats });
});

