// Create tables with PostGIS geometry
async function initDatabase() {
    try {
        await pool.query(`
            CREATE TABLE IF NOT EXISTS schools (
                id SERIAL PRIMARY KEY,
                school_id VARCHAR(50),
                name VARCHAR(255),
                lat DOUBLE PRECISION,
                lon DOUBLE PRECISION,
                geom GEOMETRY(Point, 4326),
                capacity INTEGER,
                sector VARCHAR(100),
                district VARCHAR(100),
                filename VARCHAR(255),
                date_loaded TIMESTAMP DEFAULT CURRENT_TIMESTAMP
            );
            
            CREATE TABLE IF NOT EXISTS sectors (
                id SERIAL PRIMARY KEY,
                sector_id VARCHAR(50),
                name VARCHAR(255),
                lat DOUBLE PRECISION,
                lon DOUBLE PRECISION,
                geom GEOMETRY(Point, 4326),
                population INTEGER,
                households INTEGER,
                district VARCHAR(100),
                filename VARCHAR(255),
                date_loaded TIMESTAMP DEFAULT CURRENT_TIMESTAMP
            );
            
            CREATE TABLE IF NOT EXISTS roads (
                id SERIAL PRIMARY KEY,
                road_id VARCHAR(50),
                type VARCHAR(50),
                start_lat DOUBLE PRECISION,
                start_lon DOUBLE PRECISION,
                end_lat DOUBLE PRECISION,
                end_lon DOUBLE PRECISION,
                geom GEOMETRY(LineString, 4326),
                length_km DOUBLE PRECISION,
                filename VARCHAR(255),
                date_loaded TIMESTAMP DEFAULT CURRENT_TIMESTAMP
            );
            
            CREATE TABLE IF NOT EXISTS accessibility_results (
                id SERIAL PRIMARY KEY,
                sector_name VARCHAR(255),
                sector_district VARCHAR(100),
                nearest_school VARCHAR(255),
                school_district VARCHAR(100),
                distance_km DOUBLE PRECISION,
                travel_time_min DOUBLE PRECISION,
                road_connectivity DOUBLE PRECISION,
                road_density DOUBLE PRECISION,
                category VARCHAR(50),
                priority_score DOUBLE PRECISION,
                population INTEGER,
                lat DOUBLE PRECISION,
                lon DOUBLE PRECISION,
                geom GEOMETRY(Point, 4326),
                analysis_date TIMESTAMP DEFAULT CURRENT_TIMESTAMP
            );
            
            CREATE INDEX IF NOT EXISTS idx_schools_geom ON schools USING GIST (geom);
            CREATE INDEX IF NOT EXISTS idx_sectors_geom ON sectors USING GIST (geom);
            CREATE INDEX IF NOT EXISTS idx_roads_geom ON roads USING GIST (geom);
            CREATE INDEX IF NOT EXISTS idx_results_geom ON accessibility_results USING GIST (geom);
        `);
        console.log('✅ PostGIS tables and spatial indexes created');
    } catch (err) {
        console.error('Database initialization error:', err.message);
    }
}

function calculateDistance(lat1, lon1, lat2, lon2) {
    const R = 6371;
    const dLat = (lat2 - lat1) * Math.PI / 180;
    const dLon = (lon2 - lon1) * Math.PI / 180;
    const a = Math.sin(dLat/2) * Math.sin(dLat/2) +
              Math.cos(lat1 * Math.PI/180) * Math.cos(lat2 * Math.PI/180) *
              Math.sin(dLon/2) * Math.sin(dLon/2);
    const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
    return R * c;
}

// Load CSV data to PostgreSQL
async function loadCSVToDatabase(filePath, type) {
    try {
        const content = fs.readFileSync(filePath, 'utf8');
        const records = parse(content, { columns: true, skip_empty_lines: true });
        
        let count = 0;
        const fileName = path.basename(filePath);
        
        if (type === 'schools') {
            await pool.query('DELETE FROM schools');
            for (const r of records) {
                const lat = parseFloat(r.lat || r.latitude || 0);
                const lon = parseFloat(r.lon || r.longitude || 0);
                if (lat !== 0 && lon !== 0) {
                    await pool.query(`
                        INSERT INTO schools (school_id, name, lat, lon, geom, capacity, sector, district, filename, date_loaded)
                        VALUES ($1, $2, $3, $4, ST_SetSRID(ST_MakePoint($5, $6), 4326), $7, $8, $9, $10, CURRENT_TIMESTAMP)
                    `, [
                        r.id || r.school_id || `SCH_${count}`,
                        r.name || r.school_name || 'School',
                        lat, lon, lon, lat,
                        parseInt(r.capacity) || 200,
                        r.sector || r.sector_name || 'Unknown',
                        r.district || 'Musanze',
                        fileName
                    ]);
                    count++;
                }
            }
        } 
        else if (type === 'sectors') {
            await pool.query('DELETE FROM sectors');
            for (const r of records) {
                const lat = parseFloat(r.lat || r.latitude || 0);
                const lon = parseFloat(r.lon || r.longitude || 0);
                if (lat !== 0 && lon !== 0) {
                    await pool.query(`
                        INSERT INTO sectors (sector_id, name, lat, lon, geom, population, households, district, filename, date_loaded)
                        VALUES ($1, $2, $3, $4, ST_SetSRID(ST_MakePoint($5, $6), 4326), $7, $8, $9, $10, CURRENT_TIMESTAMP)
                    `, [
                        r.id || r.sector_id || `SEC_${count}`,
                        r.name || r.sector_name || 'Sector',
                        lat, lon, lon, lat,
                        parseInt(r.population) || 5000,
                        parseInt(r.households) || 1000,
                        r.district || 'Musanze',
                        fileName
                    ]);
                    count++;
                }
            }
        }
        else if (type === 'roads') {
            await pool.query('DELETE FROM roads');
            for (const r of records) {
                const start_lat = parseFloat(r.start_lat || r.lat1 || 0);
                const start_lon = parseFloat(r.start_lon || r.lon1 || 0);
                const end_lat = parseFloat(r.end_lat || r.lat2 || 0);
                const end_lon = parseFloat(r.end_lon || r.lon2 || 0);
                if (start_lat !== 0 && start_lon !== 0 && end_lat !== 0 && end_lon !== 0) {
                    const length = parseFloat(r.length_km) || calculateDistance(start_lat, start_lon, end_lat, end_lon);
                    await pool.query(`
                        INSERT INTO roads (road_id, type, start_lat, start_lon, end_lat, end_lon, geom, length_km, filename, date_loaded)
                        VALUES ($1, $2, $3, $4, $5, $6, ST_SetSRID(ST_MakeLine(ST_MakePoint($7, $8), ST_MakePoint($9, $10)), 4326), $11, $12, CURRENT_TIMESTAMP)
                    `, [
                        r.id || r.road_id || `RD_${count}`,
                        r.type || r.road_type || 'secondary',
                        start_lat, start_lon, end_lat, end_lon,
                        start_lon, start_lat, end_lon, end_lat,
                        length,
                        fileName
                    ]);
                    count++;
                }
            }
        }
        return count;
    } catch (error) {
        console.log(`Error loading ${path.basename(filePath)}: ${error.message}`);
        return 0;
    }
}

// Find nearest school using PostGIS spatial query
async function findNearestSchool(lat, lon) {
    const query = `
        SELECT id, school_id, name, lat, lon, capacity, sector, district,
            ST_Distance(
                geom::geography,
                ST_SetSRID(ST_MakePoint($1, $2), 4326)::geography
            ) / 1000 as distance_km
        FROM schools
        ORDER BY geom::geography <-> ST_SetSRID(ST_MakePoint($1, $2), 4326)::geography
        LIMIT 1
    `;
    const result = await pool.query(query, [lon, lat]);
    return result.rows[0];
}

// Load all data
