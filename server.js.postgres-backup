        }
        else if (lowerName.includes('road')) {
            const count = await loadCSVToDatabase(filePath, 'roads');
            console.log(`   ✅ ${count} roads from ${file}`);
        }
    }
    
    const schoolResult = await pool.query('SELECT COUNT(*) as count FROM schools');
    const sectorResult = await pool.query('SELECT COUNT(*) as count FROM sectors');
