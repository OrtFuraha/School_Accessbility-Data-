    console.log('\n📂 Loading data from Desktop/DATA folder...');
    
    if (!fs.existsSync(DATA_PATH)) {
        console.log('⚠️ DATA folder not found! Creating...');
        fs.mkdirSync(DATA_PATH, { recursive: true });
